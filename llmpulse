function renderSources() {
    const lines = [section('sources', 'yellow')];
    SOURCES.forEach(([desc, ref], i) => {
        lines.push(`  [${String(i + 1).padStart(2, '0')}] ${desc}`);
        lines.push(ANSI.dim(`       ${ref}`));
