    lines.push('');
    lines.push(ANSI.dim('  Per-token energy for closed frontier models is not published.'));
    lines.push(ANSI.dim('  These constants are middle-of-range estimates; override any of'));
    lines.push(ANSI.dim('  them in ~/.config/llmpulse/config.json.'));
    return lines.join('\n');
}

// ============================================================
//   ccusage invocation
// ============================================================
function findCcusage() {
    const home = process.env.HOME || os.homedir();
    const candidates = [];
    const nvmBase = `${home}/.nvm/versions/node`;
    try {
        if (fs.existsSync(nvmBase)) {
            for (const v of fs.readdirSync(nvmBase).sort().reverse()) {
                candidates.push(`${nvmBase}/${v}/bin/ccusage`);
            }
        }
    } catch { /* ignore */ }
    candidates.push(
        `${home}/.local/bin/ccusage`,
        `${home}/.npm-global/bin/ccusage`,
        `${home}/.yarn/bin/ccusage`,
        '/opt/homebrew/bin/ccusage',
        '/usr/local/bin/ccusage',
        '/usr/bin/ccusage',
    );
    for (const c of candidates) {
        try { if (fs.existsSync(c) && fs.statSync(c).isFile()) return c; } catch { /* ignore */ }
    }
    return 'ccusage';
}

function runCcusage(args) {
    const bin = findCcusage();
    const res = spawnSync(bin, args, { encoding: 'utf8', maxBuffer: 64 * 1024 * 1024 });
    if (res.error) throw new Error(`spawn failed: ${res.error.message}`);
    if (res.status !== 0) {
        const stderr = (res.stderr || '').trim();
        throw new Error(`ccusage exited ${res.status}: ${stderr || 'no stderr'}`);
    }
    return JSON.parse(res.stdout);
}

function todayStamp() {
    const d = new Date();
    return `${d.getFullYear()}${String(d.getMonth() + 1).padStart(2, '0')}${String(d.getDate()).padStart(2, '0')}`;
}

// ============================================================
//   CLI arg parsing
// ============================================================
function parseArgs(argv) {
    const opts = {
        since: todayStamp(),
        until: null,
        json: false,
        all: false,
        help: false,
        sources: false,
        trends: false,
        models: false,
        compare: false,
        offset: false,
        region: 'global',
        config: null,
        noColor: !process.stdout.isTTY,
    };
    const takesValue = { '--since': 'since', '--until': 'until', '--region': 'region', '--config': 'config' };
    for (let i = 0; i < argv.length; i++) {
        const a = argv[i];
        if (a === '-h' || a === '--help')      opts.help = true;
        else if (a === '--json')                opts.json = true;
        else if (a === '--all')                 opts.all = true;
        else if (a === '--sources')             opts.sources = true;
        else if (a === '--trends')              opts.trends = true;
        else if (a === '--models')              opts.models = true;
        else if (a === '--compare')             opts.compare = true;
        else if (a === '--offset')              opts.offset = true;
        else if (a === '--no-color')            opts.noColor = true;
        else if (a === '--color')               opts.noColor = false;
        else if (takesValue[a])                 opts[takesValue[a]] = argv[++i];
        else {
            console.error(`llmpulse: unknown argument: ${a}`);
            console.error(`Try 'llmpulse --help'.`);
            process.exit(2);
        }
    }
    return opts;
}

function printHelp() {
    console.log(`llmpulse — climate impact of your LLM habit

USAGE
  llmpulse [flags]

PERIOD
  --since YYYYMMDD     start date (default: today)
  --until YYYYMMDD     end date
  --all                lifetime (everything ccusage knows about)

SECTIONS (default: damage panel + comparisons + verdict)
  --models             per-model breakdown (Haiku/Sonnet/Opus)
  --trends             per-day bar chart + week-over-week + sparkline
  --compare            richer real-world equivalents panel
  --offset             offset market prices for today's damage

DATA & OUTPUT
  --region CODE        ${Object.keys(GRID_INTENSITY).join(' / ')}
  --json               machine-readable JSON
  --sources            print citations for every constant
  --config PATH        override constants from a JSON file
  --no-color           disable ANSI
  -h, --help           this text

CONFIG
  Looks for ~/.config/llmpulse/config.json or ~/.llmpulserc.
  Any of these keys may be overridden:
    { "energyPerToken": { "input": 0.0004, "output": 0.002, ... },
      "modelMultiplier": { "opus": 2.5, ... },
      "gridIntensity": { "us": 384, ... } }

Numbers are best-effort middle estimates — see --sources.`);
}

// ============================================================
//   Main
// ============================================================
function main() {
    const opts = parseArgs(process.argv.slice(2));
    stripNoColor(!opts.noColor);

    if (opts.help)    { printHelp(); return; }

    const cfg = loadConfig(opts.config);
    applyConfig(cfg.data);

    if (opts.sources) {
        console.log(renderSources());
        if (cfg.path) console.log(ANSI.dim(`\n  (config loaded from ${cfg.path})`));
        return;
    }

    const region = opts.region in GRID_INTENSITY ? opts.region : 'global';
    const gridG = GRID_INTENSITY[region];

    // Ccusage args
    const args = ['daily', '--json', '--offline'];
    let label;
    if (opts.all) {
        label = 'all-time';
    } else {
        args.push('--since', opts.since);
        if (opts.until) args.push('--until', opts.until);
        label = opts.since === todayStamp() && !opts.until ? 'today'
              : opts.until ? `${opts.since}–${opts.until}`
              : `since ${opts.since}`;
    }

    let data;
    try {
        data = runCcusage(args);
    } catch (e) {
        console.error(`llmpulse: couldn't read ccusage data: ${e.message}`);
        console.error(`Is ccusage installed? Try: npm install -g ccusage`);
        process.exit(1);
    }

    const daily = Array.isArray(data.daily) ? data.daily : [];
    if (daily.length === 0) {
        console.log('llmpulse: no usage data for the selected period. The planet is briefly safe.');
        return;
    }

    const agg = aggregateImpact(daily, gridG);

    if (opts.json) {
        const out = {
            label, region, gridG,
            tokens: agg.tokens,
            impact: agg.impact,
            cost: agg.cost,
            perModel: Object.fromEntries(Object.entries(agg.perModel).map(([k, v]) => [k, { ...v, names: [...v.names] }])),
            perDay: agg.perDay,
            constants: {
                energyPerToken: BASELINE_WH_PER_TOKEN,
                modelMultiplier: MODEL_MULTIPLIER,
                mlWaterPerKwh: ML_WATER_PER_KWH,
                kgCO2PerTreeYear: KG_CO2_PER_TREE_YEAR,
                kgCO2PerTreeLifetime: KG_CO2_PER_TREE_LIFETIME,
                sccUsdPerTonne: SCC_USD_PER_TONNE_CO2,
            },
        };
        console.log(JSON.stringify(out, null, 2));
        return;
    }

    // Full text report
    const parts = [];
    parts.push(renderHeader(label, region, agg.impact.treeYears));
    parts.push('');
    parts.push(renderImpactPanel(agg.tokens, agg.impact, agg.cost));
    parts.push('');
    parts.push(renderComparisons(agg.impact));

    if (opts.models || Object.keys(agg.perModel).length > 1) {
        const m = renderModelBreakdown(agg.perModel);
        if (m) { parts.push(''); parts.push(m); }
    }

    if (opts.trends && agg.perDay.length >= 2) {
        parts.push('');
        parts.push(renderTrends(agg.perDay));
    }

    if (opts.offset) {
        parts.push('');
        parts.push(renderOffset(agg.impact));
    }

    parts.push('');
    const seed = Math.floor(agg.impact.wh * 10) + Math.floor(agg.tokens.input + agg.tokens.output);
    parts.push(renderVerdict(seed));
    parts.push('');
    parts.push(ANSI.dim(`run \`llmpulse --sources\` for citations · --trends for history · --help for more`));

    console.log(parts.join('\n'));
}

main();
