function treeArtForDamage(treeYears) {
    if (treeYears < 0.01)  return TREE_HEALTHY;
    if (treeYears < 0.1)   return TREE_STRESSED;
    if (treeYears < 1)     return TREE_DYING;
    if (treeYears < 10)    return TREE_STUMP;
    return TREE_BURNING;
}

// ============================================================
//   Config loading
// ============================================================
function loadConfig(explicitPath) {
    const candidates = explicitPath ? [explicitPath] : [
        path.join(os.homedir(), '.config', 'llmpulse', 'config.json'),
        path.join(os.homedir(), '.llmpulserc'),
    ];
    for (const p of candidates) {
        try {
            if (fs.existsSync(p)) {
                const raw = fs.readFileSync(p, 'utf8');
                return { path: p, data: JSON.parse(raw) };
            }
        } catch (e) {
            console.error(`llmpulse: bad config at ${p}: ${e.message}`);
        }
    }
    return { path: null, data: {} };
}

function applyConfig(config) {
    if (config.energyPerToken) Object.assign(BASELINE_WH_PER_TOKEN, config.energyPerToken);
    if (config.modelMultiplier) Object.assign(MODEL_MULTIPLIER, config.modelMultiplier);
    if (config.gridIntensity) Object.assign(GRID_INTENSITY, config.gridIntensity);
}

// ============================================================
//   Impact math
// ============================================================
function classifyModel(name) {
    if (!name) return 'other';
    const n = name.toLowerCase();
    if (n.includes('haiku'))  return 'haiku';
    if (n.includes('opus'))   return 'opus';
    if (n.includes('sonnet')) return 'sonnet';
    return 'other';
}

function tokensImpact(tokens, modelKey, gridG) {
    // tokens = {input, output, cacheCreate, cacheRead}
    const mult = MODEL_MULTIPLIER[modelKey] ?? MODEL_MULTIPLIER.other;
    const wh =
        (tokens.input || 0)       * BASELINE_WH_PER_TOKEN.input       * mult +
        (tokens.output || 0)      * BASELINE_WH_PER_TOKEN.output      * mult +
        (tokens.cacheCreate || 0) * BASELINE_WH_PER_TOKEN.cacheCreate * mult +
        (tokens.cacheRead || 0)   * BASELINE_WH_PER_TOKEN.cacheRead   * mult;
    const kwh = wh / 1000;
    const gCO2 = kwh * gridG;
    const mlWater = kwh * ML_WATER_PER_KWH;
    const treeYears = (gCO2 / 1000) / KG_CO2_PER_TREE_YEAR;
    const treesCut  = (gCO2 / 1000) / KG_CO2_PER_TREE_LIFETIME;
    const sccUsd    = (gCO2 / 1e6) * SCC_USD_PER_TONNE_CO2;
    return { wh, kwh, gCO2, mlWater, treeYears, treesCut, sccUsd };
}

function aggregateImpact(dailyRows, gridG) {
    // Sum per-model impact using modelBreakdowns when available.
    const totals = {
        tokens: { input: 0, output: 0, cacheCreate: 0, cacheRead: 0 },
        impact: { wh: 0, kwh: 0, gCO2: 0, mlWater: 0, treeYears: 0, treesCut: 0, sccUsd: 0 },
        cost: 0,
        perModel: {},
        perDay: [],
    };

    for (const day of dailyRows) {
        const dayTokens = { input: 0, output: 0, cacheCreate: 0, cacheRead: 0 };
        const dayImpact = { wh: 0, kwh: 0, gCO2: 0, mlWater: 0, treeYears: 0, treesCut: 0, sccUsd: 0 };

        const breakdowns = day.modelBreakdowns || [];
        if (breakdowns.length > 0) {
            for (const mb of breakdowns) {
                const mKey = classifyModel(mb.modelName);
                const t = {
                    input: mb.inputTokens || 0,
                    output: mb.outputTokens || 0,
                    cacheCreate: mb.cacheCreationTokens || 0,
                    cacheRead: mb.cacheReadTokens || 0,
                };
                const imp = tokensImpact(t, mKey, gridG);
                accumulate(totals.tokens, t);
                accumulate(totals.impact, imp);
                accumulate(dayTokens, t);
                accumulate(dayImpact, imp);

                if (!totals.perModel[mKey]) {
                    totals.perModel[mKey] = {
                        tokens: { input: 0, output: 0, cacheCreate: 0, cacheRead: 0 },
                        impact: { wh: 0, kwh: 0, gCO2: 0, mlWater: 0, treeYears: 0, treesCut: 0, sccUsd: 0 },
                        cost: 0,
                        names: new Set(),
                    };
                }
                accumulate(totals.perModel[mKey].tokens, t);
                accumulate(totals.perModel[mKey].impact, imp);
                totals.perModel[mKey].cost += mb.cost || 0;
                if (mb.modelName) totals.perModel[mKey].names.add(mb.modelName);
            }
        } else {
            // Fallback: ccusage didn't return per-model breakdown.
            const t = {
                input: day.inputTokens || 0,
                output: day.outputTokens || 0,
                cacheCreate: day.cacheCreationTokens || 0,
                cacheRead: day.cacheReadTokens || 0,
            };
            const imp = tokensImpact(t, 'sonnet', gridG); // default to sonnet class
            accumulate(totals.tokens, t);
            accumulate(totals.impact, imp);
            accumulate(dayTokens, t);
            accumulate(dayImpact, imp);
        }

        totals.cost += day.totalCost || 0;
        totals.perDay.push({
            date: day.date,
            tokens: dayTokens,
            impact: dayImpact,
            cost: day.totalCost || 0,
        });
    }
    return totals;
}

function accumulate(target, src) {
    for (const k of Object.keys(src)) target[k] = (target[k] || 0) + src[k];
}

// ============================================================
//   Formatters
// ============================================================
function fmtTokens(n) {
    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';
    if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';
    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
    return String(n | 0);
}
function fmtEnergy(wh) {
    if (wh >= 1e6) return (wh / 1e6).toFixed(2) + ' MWh';
    if (wh >= 1e3) return (wh / 1e3).toFixed(2) + ' kWh';
    if (wh >= 1)   return wh.toFixed(2) + ' Wh';
    return (wh * 1000).toFixed(1) + ' mWh';
}
function fmtCO2(g) {
    if (g >= 1e6) return (g / 1e6).toFixed(2) + ' t';
    if (g >= 1e3) return (g / 1e3).toFixed(2) + ' kg';
    if (g >= 1)   return g.toFixed(2) + ' g';
    return (g * 1000).toFixed(1) + ' mg';
}
function fmtWater(ml) {
    if (ml >= 1e6) return (ml / 1e6).toFixed(2) + ' kL';
    if (ml >= 1e3) return (ml / 1e3).toFixed(2) + ' L';
    return ml.toFixed(2) + ' mL';
}
function fmtTrees(n) {
    if (n >= 10)    return n.toFixed(1);
    if (n >= 0.01)  return n.toFixed(3);
    if (n <= 0)     return '0';
    return n.toExponential(2);
}
function fmtUSD(n) {
    if (n >= 1)    return '$' + n.toFixed(2);
    if (n >= 0.01) return '$' + n.toFixed(4);
    return '$' + n.toExponential(2);
}

// ============================================================
//   ANSI
// ============================================================
const ANSI = {
    bold:   s => `\x1b[1m${s}\x1b[0m`,
    dim:    s => `\x1b[2m${s}\x1b[0m`,
    green:  s => `\x1b[32m${s}\x1b[0m`,
    yellow: s => `\x1b[33m${s}\x1b[0m`,
    red:    s => `\x1b[31m${s}\x1b[0m`,
    cyan:   s => `\x1b[36m${s}\x1b[0m`,
    magenta:s => `\x1b[35m${s}\x1b[0m`,
    blue:   s => `\x1b[34m${s}\x1b[0m`,
    brown:  s => `\x1b[38;5;130m${s}\x1b[0m`,
};

function stripNoColor(useColor) {
    if (!useColor) {
        for (const k of Object.keys(ANSI)) ANSI[k] = s => s;
    }
}

// ============================================================
//   Sections
// ============================================================
function section(title, color = 'green') {
    return ANSI.bold(ANSI[color](`── ${title} ${'─'.repeat(Math.max(0, 60 - title.length - 4))}`));
}

function renderHeader(label, region, treeYears) {
    const lines = treeArtForDamage(treeYears);
    const colored = lines.map(l => ANSI.green(l));
    const title = ANSI.bold(ANSI.green('llmpulse — climate crime report'));
    const sub = ANSI.dim(`period: ${label}    grid: ${region} (${GRID_INTENSITY[region]} gCO₂/kWh)`);
    return [
        colored[0] + '   ' + title,
        colored[1] + '   ' + sub,
        colored[2],
        colored[3],
        colored[4],
        colored[5],
        colored[6],
    ].join('\n');
}

function renderImpactPanel(tokens, impact, cost) {
    const total = tokens.input + tokens.output + tokens.cacheCreate + tokens.cacheRead;
    const lines = [];
    lines.push(section('the damage'));
    lines.push(`${ANSI.bold('🔥 Tokens vaporized')}        ${fmtTokens(total)}`);
    lines.push(ANSI.dim(`   input ${fmtTokens(tokens.input)}   output ${fmtTokens(tokens.output)}   cache-write ${fmtTokens(tokens.cacheCreate)}   cache-read ${fmtTokens(tokens.cacheRead)}`));
    lines.push('');
    lines.push(`${ANSI.yellow('⚡ Energy burned')}           ${fmtEnergy(impact.wh)}`);
    lines.push(`${ANSI.red('☁  CO₂ belched')}            ${fmtCO2(impact.gCO2)}`);
    lines.push(`${ANSI.cyan('💧 Water evaporated')}        ${fmtWater(impact.mlWater)}`);
    lines.push(`${ANSI.green('🌲 Tree-years to offset')}    ${fmtTrees(impact.treeYears)}`);
    lines.push(`${ANSI.brown('🪓 Trees-cut-equivalent')}    ${fmtTrees(impact.treesCut)}`);
    lines.push(`${ANSI.magenta('💀 Social cost of carbon')}   ${fmtUSD(impact.sccUsd)}`);
    if (cost > 0) lines.push(`${ANSI.blue('💸 Your wallet paid')}        ${fmtUSD(cost)}`);
    return lines.join('\n');
}

function renderModelBreakdown(perModel) {
    const keys = Object.keys(perModel).filter(k => perModel[k].tokens.input + perModel[k].tokens.output + perModel[k].tokens.cacheCreate + perModel[k].tokens.cacheRead > 0);
    if (keys.length === 0) return null;
    const lines = [section('per-model breakdown', 'yellow')];
    lines.push(`${'model'.padEnd(10)} ${'tokens'.padStart(10)}  ${'energy'.padStart(11)}  ${'CO₂'.padStart(10)}  ${'trees'.padStart(8)}  ${'mult'.padStart(5)}`);
    lines.push(ANSI.dim('─'.repeat(60)));
    for (const k of keys) {
        const pm = perModel[k];
        const toks = pm.tokens.input + pm.tokens.output + pm.tokens.cacheCreate + pm.tokens.cacheRead;
        lines.push(
            `${k.padEnd(10)} ${fmtTokens(toks).padStart(10)}  ${fmtEnergy(pm.impact.wh).padStart(11)}  ${fmtCO2(pm.impact.gCO2).padStart(10)}  ${fmtTrees(pm.impact.treeYears).padStart(8)}  ${String(MODEL_MULTIPLIER[k] ?? 1).padStart(5)}x`
        );
    }
    return lines.join('\n');
}

function renderComparisons(impact) {
    const g = impact.gCO2;
    const wh = impact.wh;
    const lines = [section('thats equivalent to', 'cyan')];
    const rows = [];
    for (const eq of EQUIVALENTS) {
        const n = g / eq.g;
        if (n >= 0.01 && n < 10_000_000) rows.push({ n, label: eq.label, unit: eq.unit });
    }
    // Sort: most intuitive are around 0.5–50
    rows.sort((a, b) => Math.abs(Math.log10(Math.max(a.n, 1e-9)) - 0) - Math.abs(Math.log10(Math.max(b.n, 1e-9)) - 0));
    const pick = rows.slice(0, 6);
    for (const r of pick) {
        const nStr = r.n >= 100 ? r.n.toFixed(0) : r.n >= 1 ? r.n.toFixed(2) : r.n.toFixed(3);
        lines.push(`  ${ANSI.bold(nStr.padStart(8))}  ${r.label}`);
    }
    // Also an energy one-liner
    lines.push('');
    const ledHours = wh / 10;
    if (ledHours < 1) lines.push(ANSI.dim(`  …or ${(ledHours * 60).toFixed(1)} minutes of a 10 W LED bulb.`));
    else lines.push(ANSI.dim(`  …or ${ledHours.toFixed(1)} hours of a 10 W LED bulb.`));
    return lines.join('\n');
}

function renderTrends(perDay) {
    if (perDay.length < 2) return null;
    const lines = [section('last ' + perDay.length + ' days', 'blue')];
    const max = Math.max(...perDay.map(d => d.impact.wh));
    const bars = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];
    for (const d of perDay.slice().reverse()) {
        const frac = max > 0 ? d.impact.wh / max : 0;
        const barLen = 20;
        const filled = Math.round(frac * barLen);
        const bar = '█'.repeat(filled) + ANSI.dim('·'.repeat(barLen - filled));
        lines.push(`  ${d.date}  ${bar}  ${fmtEnergy(d.impact.wh).padStart(10)}  ${fmtCO2(d.impact.gCO2).padStart(10)}`);
    }
    // Sparkline
    const spark = perDay.map(d => {
        const frac = max > 0 ? d.impact.wh / max : 0;
        return bars[Math.min(bars.length - 1, Math.round(frac * (bars.length - 1)))];
    }).join('');
    lines.push('');
    lines.push(`  sparkline: ${ANSI.green(spark)}`);

    // Week-over-week if we have ≥14 days
    if (perDay.length >= 14) {
        const last7 = perDay.slice(-7).reduce((s, d) => s + d.impact.gCO2, 0);
        const prev7 = perDay.slice(-14, -7).reduce((s, d) => s + d.impact.gCO2, 0);
        const delta = prev7 > 0 ? ((last7 - prev7) / prev7) * 100 : 0;
        const arrow = delta > 0 ? '▲' : '▼';
        const color = delta > 0 ? ANSI.red : ANSI.green;
        lines.push('');
        lines.push(`  WoW: ${color(arrow + ' ' + Math.abs(delta).toFixed(0) + '%')}   last 7d: ${fmtCO2(last7)}   prev 7d: ${fmtCO2(prev7)}`);
    }

    // Biggest day
    const biggest = perDay.slice().sort((a, b) => b.impact.gCO2 - a.impact.gCO2)[0];
    lines.push('');
    lines.push(`  biggest offender: ${ANSI.red(biggest.date)}  ${fmtCO2(biggest.impact.gCO2)}  (${fmtTokens(biggest.tokens.input + biggest.tokens.output + biggest.tokens.cacheCreate + biggest.tokens.cacheRead)} tokens)`);
    return lines.join('\n');
}

function renderOffset(impact) {
    const tonnes = impact.gCO2 / 1e6;
    const lines = [section('offset options', 'magenta')];
    // Typical voluntary offset market prices (2024-2025): $5-20/tonne for
    // nature-based, $200-500/tonne for DAC/sequestration.
    const natureUsd = tonnes * 15;
    const dacUsd    = tonnes * 300;
    lines.push(`  nature-based offset   ${fmtUSD(natureUsd)}   (~$15/t, voluntary market)`);
    lines.push(`  direct air capture    ${fmtUSD(dacUsd)}   (~$300/t, Climeworks/Heirloom tier)`);
    const treeYears = impact.treeYears;
    lines.push(`  plant & grow trees    ${fmtTrees(treeYears)} tree-years of absorption required`);
    return lines.join('\n');
}

function renderVerdict(seed) {
    return ANSI.dim(`💬 ${VERDICTS[seed % VERDICTS.length]}`);
}

