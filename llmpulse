#!/usr/bin/env node
// llmpulse — climate-impact accounting for your Claude Code habit.
//
// Reads ccusage daily data and converts tokens into energy / CO2 / water /
// tree-equivalents / social cost, using published ranges for LLM inference
// and grid electricity. Constants are editable via a config file and every
// number is backed by a cite-able source (`llmpulse --sources`).
//
// This is still an approximation — vendors don't publish per-token energy —
// but the numbers here sit inside the peer-reviewed / industry-reported
// range rather than being pulled from thin air.

'use strict';

const fs = require('fs');
const path = require('path');
const os = require('os');
const { spawnSync } = require('child_process');

// ============================================================
//   Sourced constants (see SOURCES[] at bottom of file)
// ============================================================

// Per-token energy in Wh. Derived from:
//  - GPT-4o: 0.34-0.43 Wh per ~500-token query (Altman 2025, Epoch AI 2025)
//  - Claude Opus 4.5: ~390 Wh/Mtok input, ~1,950 Wh/Mtok output
//    (Couch 2026, Claude Code impact analysis)
//  - Cache reads are substantially cheaper (mostly KV-cache reuse;
//    Anthropic prices them at 10% of fresh input, so use that as a proxy).
// These are Sonnet-class baselines; multiplied by MODEL_MULTIPLIER below.
const BASELINE_WH_PER_TOKEN = {
    input: 0.00040,
    output: 0.00200,
    cacheCreate: 0.00040,
    cacheRead: 0.00004,
};

// Model multipliers over Sonnet baseline. Scaled to match Anthropic's
// list pricing, which roughly tracks compute & therefore energy:
//   Haiku  : ~$1 / $5  per Mtok  (≈0.3x Sonnet)
//   Sonnet : ~$3 / $15 per Mtok  (1.0x, baseline)
//   Opus   : ~$5 / $25 per Mtok  (≈2.0x)
// (Finout Anthropic pricing guide 2026; IntuitionLabs 2025.)
const MODEL_MULTIPLIER = {
    haiku: 0.3,
    sonnet: 1.0,
    opus: 2.0,
    other: 1.0,
};

// Grid carbon intensity (g CO2 / kWh), from Ember Global Electricity Review
// 2024/2025 lifecycle figures. (`global` = Ember 473 g/kWh world average.)
const GRID_INTENSITY = {
    global: 473,
    us: 384,
    eu: 213,
    in: 708,
    cn: 560,
    ru: 449,
    fr: 55,
    no: 23,
    uk: 170,
    jp: 450,
    au: 550,
    ca: 120,
    de: 350,
    br: 100,
};

// Datacenter water: 1.8 L/kWh covers on-site evaporative cooling + upstream
// thermoelectric cooling for the grid electricity drawn, based on Mytton
// 2021 and de Vries 2023. Sam Altman's 2025 figure (0.32 mL/query) is
// on-site only and sits below this; the higher number captures full
// lifecycle water draw.
const ML_WATER_PER_KWH = 1800;

// Tree absorption. 21.77 kg CO2/tree/year for a mature hardwood over 40
// years is the common US Forest Service figure; tree-lifetime storage is
// a very wide range (200-1000 kg), so use 450 kg as a midpoint and label
// it as "equivalent".
const KG_CO2_PER_TREE_YEAR = 21.77;
const KG_CO2_PER_TREE_LIFETIME = 450;

// Social cost of CO2 (2025 USD). EPA Final Rule Nov 2023 → $255/tonne
// for 2025 emissions at a 2% near-term discount rate.
const SCC_USD_PER_TONNE_CO2 = 255;

// Real-world CO2 equivalents in grams, for the `--compare` section.
// Sources on each line.
const EQUIVALENTS = [
    // (label, gCO2, unit)
    { label: 'beef burger (100 g patty)',   g: 3000,  unit: 'burger'  }, // Poore & Nemecek 2018
    { label: 'km driven in an average car', g: 120,   unit: 'km'      }, // EPA 2023
    { label: 'km flown (economy)',          g: 90,    unit: 'km'      }, // ICAO carbon calculator
    { label: 'Google search',               g: 0.2,   unit: 'search'  }, // Google 2009 / refreshed estimates
    { label: 'hour of Netflix',             g: 36,    unit: 'hour'    }, // Carbon Trust 2021
    { label: 'smartphone charge',           g: 4,     unit: 'charge'  }, // Apple product env reports
    { label: '8-min hot shower',            g: 600,   unit: 'shower'  }, // UK EST
    { label: 'boiled kettle (1 L)',         g: 43,    unit: 'boil'    }, // 0.09 kWh × 475 g/kWh
    { label: 'cheeseburger meal',           g: 4000,  unit: 'meal'    }, // Our World in Data
    { label: 'hour of LED bulb (10 W)',     g: 4.73,  unit: 'hour'    }, // 10 Wh × 473 g/kWh
];

